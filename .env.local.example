# ==============================================
# Les Jardins de Sofie — Configuration
# ==============================================
# 
# ⚡ MODE DEMO: Laisse ces valeurs vides pour utiliser
#    les données de démo (pas besoin de Shopify pour voir le site)
#
# 🛒 MODE SHOPIFY: Remplis avec tes vraies clés pour
#    connecter à ta boutique Shopify
#
# ÉTAPE 1: Shopify Admin → Settings → Apps → Develop apps
# ÉTAPE 2: Crée une app, active les Storefront API scopes
# ÉTAPE 3: Copie le Storefront access token ci-dessous

NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=
NEXT_PUBLIC_SHOPIFY_STOREFRONT_TOKEN=

# URL du site
NEXT_PUBLIC_SITE_URL=https://lesjardinsdesofie.com
